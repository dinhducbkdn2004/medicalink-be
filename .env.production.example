# =============================================================================
# MedicaLink — Production (Docker trên VM, network medicalink-network)
# Sao chép: cp .env.production.example .env.production
# Điền mọi giá trị __YOUR_*__ / CHANGE_ME — không commit .env.production
#
# Hostname dùng TÊN SERVICE trong Compose: postgres, rabbitmq, redis, ...
# Phải khớp POSTGRES_PASSWORD / RABBITMQ_PASS trong deployment/docker-compose*
# =============================================================================

# --- PostgreSQL (user medicalink tạo bởi scripts/init-db.sh) ---
# Mật khẩu: trùng POSTGRES_PASSWORD bạn đặt cho container postgres
ACCOUNTS_DATABASE_URL="postgresql://medicalink:__YOUR_POSTGRES_PASSWORD__@postgres:5432/medicalink_accounts?connection_limit=5&pool_timeout=20"
BOOKING_DATABASE_URL="postgresql://medicalink:__YOUR_POSTGRES_PASSWORD__@postgres:5432/medicalink_booking?connection_limit=5&pool_timeout=20"
PROVIDER_DATABASE_URL="postgresql://medicalink:__YOUR_POSTGRES_PASSWORD__@postgres:5432/medicalink_provider?connection_limit=5&pool_timeout=20"
CONTENT_DATABASE_URL="postgresql://medicalink:__YOUR_POSTGRES_PASSWORD__@postgres:5432/medicalink_content?connection_limit=5&pool_timeout=20"
NOTIFICATION_DATABASE_URL="postgresql://medicalink:__YOUR_POSTGRES_PASSWORD__@postgres:5432/medicalink_notification?connection_limit=5&pool_timeout=20"

# --- Redis (service: redis, cổng nội bộ 6379 — không dùng 15796 như dev local)
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_USERNAME=default
REDIS_PORT=6379
REDIS_DB=0

# --- RabbitMQ (trùng RABBITMQ_USER / RABBITMQ_PASS trong docker-compose.infrastructure)
RABBITMQ_URL="amqp://__YOUR_RABBITMQ_USER__:__YOUR_RABBITMQ_PASS__@rabbitmq:5672"

SERVICE_NAME=medicalink

# --- JWT (chuỗi ngẫu nhiên dài, production)
JWT_ACCESS_SECRET=__YOUR_JWT_ACCESS_SECRET_MIN_32_CHARS__
JWT_EXPIRES_IN=900
JWT_REFRESH_SECRET=__YOUR_JWT_REFRESH_SECRET_MIN_32_CHARS__
JWT_REFRESH_EXPIRES_IN=604800

API_GATEWAY_PORT=3000

# Throttler
THROTTLER_SHORT_TTL=1000
THROTTLER_SHORT_LIMIT=20
THROTTLER_LONG_TTL=60000
THROTTLER_LONG_LIMIT=200

# Orchestrator
ORCHESTRATOR_CACHE_TTL_SHORT=120
ORCHESTRATOR_CACHE_TTL_MEDIUM=300
ORCHESTRATOR_SAGA_TIMEOUT=30000
ORCHESTRATOR_SERVICE_TIMEOUT=10000

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=__YOUR_SMTP_EMAIL__
SMTP_PASS=__YOUR_SMTP_APP_PASSWORD__

NODE_ENV=production
APP_NAME="MedicaLink Microservices"
API_VERSION=v1

# Seed super-admin (chỉ dùng khi chạy script seed lần đầu — đổi sau khi đã tạo user)
SUPER_ADMIN_EMAIL=__YOUR_ADMIN_EMAIL__
SUPER_ADMIN_PASSWORD=__YOUR_ADMIN_PASSWORD__
SUPER_ADMIN_FULL_NAME="Super Administrator"

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=__YOUR_CLOUDINARY_CLOUD_NAME__
CLOUDINARY_API_KEY=__YOUR_CLOUDINARY_API_KEY__
CLOUDINARY_API_SECRET=__YOUR_CLOUDINARY_API_SECRET__

# --- Google GenAI (optional — microservice / tích hợp LLM) ---
GOOGLE_GENAI_API_KEY=__YOUR_GOOGLE_GENAI_API_KEY_OR_LEAVE_EMPTY__
GOOGLE_GENAI_MODEL=gemini-2.0-flash
GOOGLE_GENAI_TIMEOUT=30000

# Production: tắt log Prisma chi tiết
# DEBUG=
